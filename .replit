[agent]
expertMode = true

[nix]
packages = ["nano"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run"

[[workflows.workflow]]
name = "Run"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "gcc main.c -o main && ./main"

[workflows.workflow.metadata]
outputType = "console"
